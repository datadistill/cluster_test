# PostgreSQL Cluster Test Environment Variables
# Copy this file to .env and adjust values for your environment

# Primary database connection through PgBouncer
# Use service names when running in Docker with pg_network
PRIMARY_DB=postgres-primary:5432

# Direct PostgreSQL connection (bypasses PgBouncer)
# Required for pg_stat_replication and read_user permission tests
DIRECT_PRIMARY_DB=postgres-primary:5432

# Comma-separated list of replica connections
REPLICA_DBS=postgres-replica-1:5432,postgres-replica-2:5432

# PgBouncer connection
BOUNCER_DB=pgbouncer:5432

# Database credentials
POSTGRES_USER=db_admin_prod
POSTGRES_PASSWORD=your_admin_password_here
POSTGRES_DB=postgres

# Replication credentials
REPLICATION_USER=stream_replicator
REPLICATION_PASSWORD=your_replication_password_here

# Application user credentials
APP_USER=app_user_prod
APP_PASSWORD=your_app_password_here

# Read-only user credentials
READ_USER=read_user_prod
READ_PASSWORD=your_read_password_here

# Monitoring URLs (optional)
POSTGRES_EXPORTER_URL=http://127.0.0.1:9187
PROMETHEUS_URL=http://127.0.0.1:9090
GRAFANA_URL=http://127.0.0.1:3000

# Replication lag wait time in seconds (optional)
REPLICATION_LAG_WAIT=3

# ============================================================================
# For local development without Docker network:
# ============================================================================
# PRIMARY_DB=127.0.0.1:5432
# DIRECT_PRIMARY_DB=127.0.0.1:5432
# REPLICA_DBS=127.0.0.1:5433,127.0.0.1:5434
# BOUNCER_DB=127.0.0.1:6432

